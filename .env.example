PORT=3000
POLL_INTERVAL_MS=30000
MONGO_URI=mongodb://localhost:27017/bambufarm

# APNs Live Activity push (optional — LA pushes disabled if not set)
# Use APNS_KEY_CONTENTS for cloud (Railway) or APNS_KEY_PATH for local file
APNS_KEY_PATH=./data/AuthKey_XXXXXXXXXX.p8
APNS_KEY_CONTENTS=-----BEGIN PRIVATE KEY-----\nXXXXXX\n-----END PRIVATE KEY-----
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_HOST=api.sandbox.push.apple.com
