{
  "name": "bambubridge",
  "version": "1.0.0",
  "description": "BambuBridge — relay your Bambu Lab printer cameras to the cloud",
  "main": "electron-main.js",
  "bin": {
    "bambubridge": "./index.js"
  },
  "scripts": {
    "start": "node index.js",
    "electron": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder --mac --win --linux"
  },
  "build": {
    "appId": "com.bambubridge.app",
    "productName": "BambuBridge",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!dist-electron/**"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "identity": "DEGEN TECH SAS (6CS77TWQLQ)",
      "notarize": true,
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "icon": "icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "icon.png",
      "category": "Utility"
    }
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "mqtt": "^5.15.0",
    "open": "^10.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^25.0.0"
  }
}
